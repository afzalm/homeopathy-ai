# ── App ─────────────────────────────────────────────────
APP_NAME=Homeopathy AI
DEBUG=false
SECRET_KEY=your-secret-key-here
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── SQLite (Development) ────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./homeopathy_ai.db

# ── PostgreSQL (Production) ─────────────────────────────
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/homeopathy_ai

# ── Neo4j ────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── LLM ─────────────────────────────────────────────────
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4.1-mini
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:8000
OPENROUTER_APP_TITLE=Homeopathy AI DSS
# ANTHROPIC_API_KEY=your-anthropic-api-key
# OPENAI_API_KEY=your-openai-api-key

# ── Ranking weights ──────────────────────────────────────
WEIGHT_REPERTORY=0.50
WEIGHT_RAG=0.30
WEIGHT_OUTCOME=0.20
